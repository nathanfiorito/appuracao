# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default

# DynamoDB
BULLETINS_TABLE=appuracao-bulletins
PARTIAL_QR_TABLE=appuracao-partial-qrcodes

# S3
RESULTS_BUCKET=appuracao-results

# Step Functions
STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:appuracao-bulletin-processing

# TSE Public Keys (hex-encoded)
# Download from: https://www.tse.jus.br/eleicoes/eleicoes-anteriores/eleicoes-2024/boletim-de-urna
TSE_PUBLIC_KEY_HEX=

# CloudFront
CLOUDFRONT_DISTRIBUTION_ID=
RESULTS_BASE_URL=https://dXXXXXXXXXXX.cloudfront.net
